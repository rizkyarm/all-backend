# ================================
# Environment Variables Template
# ================================
# Copy to .env and fill in real values.
# For Supabase deployment, see .env.supabase instead.

NODE_ENV=development
PORT=3000

# ── Database ──
DB_HOST=
DB_PORT=5432
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE=
DATABASE_URL=

# ── JWT ──
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ── Redis ──
# Option A (Upstash / cloud): just paste the full URL
REDIS_URL=
# Option B (local Docker): use individual host/port/password
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# ── Storage (MinIO local / Supabase S3) ──
MINIO_ENDPOINT=
MINIO_PORT=9000
MINIO_PUBLIC_ENDPOINT=
MINIO_PUBLIC_PORT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET_NAME=
MINIO_USE_SSL=false

# ── Bcrypt ──
BCRYPT_SALT_ROUNDS=12

# ── Frontend ──
FRONTEND_URL=
